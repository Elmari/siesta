{
  "name": "siesta",
  "version": "0.1.0",
  "description": "CLI presence-stamping for intranet — moin, ciao, mahlzeit.",
  "type": "module",
  "bin": {
    "siesta": "dist/index.js",
    "moin": "dist/index.js",
    "ciao": "dist/index.js",
    "mahlzeit": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "js-yaml": "^4.1.0",
    "keytar": "^7.9.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.49.0",
    "prompts": "^2.4.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
