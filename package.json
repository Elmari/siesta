{
  "name": "siesta",
  "version": "0.1.0",
  "description": "CLI presence-stamping for intranet time-tracking — moin, ciao, mahlzeit.",
  "type": "module",
  "bin": {
    "siesta": "dist/index.js",
    "moin": "dist/index.js",
    "ciao": "dist/index.js",
    "mahlzeit": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('dist/index.js', 0o755)\"",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepare": "tsc"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0",
    "keytar": "^7.9.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "playwright": "^1.49.0",
    "prompts": "^2.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.1",
    "@types/prompts": "^2.4.9",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  }
}
